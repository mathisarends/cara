OPENAI_API_KEY=your_open_api_key

# Philips Hue - run scripts/discover_hue.sh to obtain these
HUE_BRIDGE_IP=your_hue_bridge_ip
HUE_APP_KEY=your_hue_app_key

# Sonos - run scripts/discover_sonos.sh to obtain this
# Optional: without it playback falls back to network discovery
SONOS_IP_ADDRESS=your_sonos_ip_address
SONOS_SPEAKER_NAME=your_sonos_speaker_name

ELEVENLABS_API_KEY=your_eleven_labs_api_key
